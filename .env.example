# Environment Variables Template
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control!

# Contact Form Backend Integration
REACT_APP_FORM_ENDPOINT=https://your-api.com/contact
REACT_APP_FORM_SERVICE_ID=your_formspree_id

# Email Configuration
REACT_APP_CONTACT_EMAIL=ahmed.ragab@example.com

# Social Media Links
REACT_APP_GITHUB_URL=https://github.com/ahmedragab13579
REACT_APP_LINKEDIN_URL=https://linkedin.com/in/your-profile
REACT_APP_EMAIL_URL=mailto:ahmed.ragab@example.com

# CV/Resume Link
REACT_APP_CV_DOWNLOAD_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing

# Analytics (Optional)
REACT_APP_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# API Keys (if needed for future features)
REACT_APP_API_KEY=your_api_key_here
REACT_APP_API_BASE_URL=https://api.example.com

# Feature Flags
REACT_APP_ENABLE_BLOG=false
REACT_APP_ENABLE_CONTACT_FORM=true

# Build Environment
NODE_ENV=development
